#!/usr/bin/env bash

set -u

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
COMMON=${NOIR_DWM_COMMON:-$SCRIPT_DIR/lib/noir-common.sh}
[[ -r $COMMON ]] || COMMON=/usr/local/lib/noir-dwm/noir-common.sh
# shellcheck source=scripts/lib/noir-common.sh
source "$COMMON"

action=${1:-status}
[[ -n ${BLOCK_BUTTON:-} ]] && action=launch

build_app_map() {
	local map=$1
	python - "$map" <<'PY'
import configparser
import os
import shutil
import sys

map_path = sys.argv[1]
home = os.path.expanduser("~")
dirs = [
    os.path.join(home, ".local/share/applications"),
    os.path.join(home, ".local/share/flatpak/exports/share/applications"),
    "/usr/local/share/applications",
    "/var/lib/flatpak/exports/share/applications",
    "/usr/share/applications",
]
desktop_names = {"dwm", "noirLang", "GNOME", "KDE", "XFCE", "X-Cinnamon"}

def truthy(value):
    return str(value or "").strip().lower() == "true"

def split_list(value):
    return {item for item in str(value or "").split(";") if item}

def clean(value):
    return " ".join(str(value or "").replace("\x00", "").replace("\t", " ").split())

def runnable(try_exec):
    if not try_exec:
        return True
    if os.path.isabs(try_exec):
        return os.access(try_exec, os.X_OK)
    return shutil.which(try_exec) is not None

apps = []
seen = set()
for base in dirs:
    if not os.path.isdir(base):
        continue
    for root, _, files in os.walk(base):
        for filename in files:
            if not filename.endswith(".desktop"):
                continue
            path = os.path.join(root, filename)
            parser = configparser.ConfigParser(interpolation=None, strict=False)
            parser.optionxform = str
            try:
                with open(path, "r", encoding="utf-8", errors="replace") as handle:
                    parser.read_file(handle)
            except Exception:
                continue
            if "Desktop Entry" not in parser:
                continue
            entry = parser["Desktop Entry"]
            if entry.get("Type") != "Application":
                continue
            if truthy(entry.get("NoDisplay")) or truthy(entry.get("Hidden")):
                continue
            if not runnable(entry.get("TryExec")):
                continue

            only_show = split_list(entry.get("OnlyShowIn"))
            not_show = split_list(entry.get("NotShowIn"))
            if only_show and not (only_show & desktop_names):
                continue
            if not_show and (not_show & desktop_names):
                continue

            name = clean(entry.get("Name[tr]") or entry.get("Name"))
            exec_line = clean(entry.get("Exec"))
            if not name or not exec_line:
                continue
            key = (name.casefold(), exec_line.casefold())
            if key in seen:
                continue
            seen.add(key)
            apps.append((name.casefold(), name, path))

apps.sort(key=lambda item: item[0])
with open(map_path, "w", encoding="utf-8") as handle:
    for _, name, path in apps:
        handle.write(f"{name}\t{path}\n")
PY
}

launch_desktop() {
	local desktop=$1 desktop_id

	[[ -n $desktop ]] || return 1
	if command -v gio >/dev/null 2>&1 \
		&& setsid -f gio launch "$desktop" >/dev/null 2>&1; then
		return 0
	fi
	if command -v gtk-launch >/dev/null 2>&1; then
		desktop_id=${desktop##*/}
		desktop_id=${desktop_id%.desktop}
		setsid -f gtk-launch "$desktop_id" >/dev/null 2>&1
		return 0
	fi
	noir_notify critical noirLang 'gio veya gtk-launch bulunamadi.'
	return 1
}

launch_menu() {
	local map choice desktop

	map=$(mktemp "${TMPDIR:-/tmp}/noir-apps.XXXXXX")
	trap 'rm -f "$map"' EXIT
	build_app_map "$map"
	[[ -s $map ]] || {
		noir_notify critical noirLang 'Uygulama bulunamadi.'
		exit 1
	}

	choice=$(cut -f1 "$map" | noir_menu noirLang) || exit 0
	[[ -n $choice ]] || exit 0
	desktop=$(awk -F '\t' -v choice="$choice" '$1 == choice { print $2; exit }' "$map")
	launch_desktop "$desktop"
}

run_command() {
	local cmd

	if command -v dmenu_path >/dev/null 2>&1 && command -v dmenu >/dev/null 2>&1; then
		cmd=$(dmenu_path | noir_menu Calistir) || exit 0
		[[ -n $cmd ]] || exit 0
		setsid -f sh -c "$cmd" >/dev/null 2>&1
	else
		noir_notify critical noirLang 'dmenu bulunamadi.'
		exit 1
	fi
}

case $action in
	status)
		printf 'noirLang\n'
		;;
	launch | menu)
		launch_menu
		;;
	run)
		run_command
		;;
	*)
		printf 'Kullanim: %s [status|launch|run]\n' "${0##*/}" >&2
		exit 2
		;;
esac
