#!/usr/bin/env bash

set -u

laptop=${NOIR_LAPTOP_OUTPUT:-DP-2}
external=${NOIR_EXTERNAL_OUTPUT:-HDMI-0}
mode=${NOIR_DISPLAY_MODE:-1920x1080}
laptop_rate=${NOIR_LAPTOP_RATE:-144}
external_rate=${NOIR_EXTERNAL_RATE:-60}

connected() {
	xrandr --query | awk -v output="$1" '$1 == output && $2 == "connected" { found = 1 } END { exit !found }'
}

apply_layout() {
	local -a cmd=(xrandr)

	if connected "$laptop"; then
		cmd+=(--output "$laptop" --mode "$mode" --rate "$laptop_rate" --primary --pos 0x0)
		if connected "$external"; then
			cmd+=(--output "$external" --mode "$mode" --rate "$external_rate" --right-of "$laptop")
		fi
	elif connected "$external"; then
		cmd+=(--output "$external" --mode "$mode" --rate "$external_rate" --primary --pos 0x0)
	else
		return 0
	fi

	"${cmd[@]}"
}

if ! command -v xrandr >/dev/null 2>&1; then
	exit 0
fi

apply_layout
